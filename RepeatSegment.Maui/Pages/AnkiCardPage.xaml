<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RepeatSegment.Maui.Pages.AnkiCardPage"
             Title="Anki Card"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="True"
             Shell.BackgroundColor="#1E1E1E"
             Shell.ForegroundColor="#E0E0E0"
             Shell.TitleColor="#E0E0E0">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto"
          Padding="10" RowSpacing="4">

        <!-- 0: Deck -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="4" Padding="0,2">
            <Label Grid.Column="0" Text="Deck:" TextColor="#CCC" FontSize="13" VerticalOptions="Center" FontAttributes="Bold"/>
            <Picker Grid.Column="1" x:Name="PckDeck" TextColor="#E0E0E0" BackgroundColor="#2A2A3E"
                    TitleColor="#666" FontSize="13" Title="Select deck" VerticalOptions="Center"/>
            <Button Grid.Column="2" x:Name="BtnRefreshDecks" Text="↻" FontSize="14"
                    Clicked="OnRefreshDecksClicked"
                    BackgroundColor="#444" TextColor="#CCC" CornerRadius="6"
                    HeightRequest="32" WidthRequest="36" Padding="0" VerticalOptions="Center"/>
            <Button Grid.Column="3" x:Name="BtnNewDeck" Text="+ New" FontSize="12"
                    Clicked="OnNewDeckClicked"
                    BackgroundColor="#444" TextColor="#CCC" CornerRadius="6"
                    HeightRequest="32" Padding="6,0" VerticalOptions="Center"/>
            <Button Grid.Column="4" x:Name="BtnOpenDecks" Text="Open" FontSize="12"
                    Clicked="OnOpenDecksClicked"
                    BackgroundColor="#444" TextColor="#00B4A6" CornerRadius="6"
                    HeightRequest="32" Padding="6,0" VerticalOptions="Center"/>
        </Grid>

        <!-- 1: EN -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="6" Padding="0,2">
            <Label Grid.Column="0" Text="EN:" TextColor="#CCC" FontSize="13" VerticalOptions="Center" FontAttributes="Bold" WidthRequest="90"/>
            <Entry Grid.Column="1" x:Name="TxtEn" TextColor="#E0E0E0" BackgroundColor="#2A2A3E" FontSize="14" PlaceholderColor="#555" Placeholder="English word"/>
        </Grid>

        <!-- 2: Transcription (IPA) -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="6" Padding="0,2">
            <Label Grid.Column="0" Text="Transcription:" TextColor="#CCC" FontSize="12" VerticalOptions="Center" WidthRequest="90"/>
            <Entry Grid.Column="1" x:Name="TxtTranscription" TextColor="#E0E0E0" BackgroundColor="#2A2A3E" FontSize="13" PlaceholderColor="#555" Placeholder="Auto IPA lookup..."/>
        </Grid>

        <!-- 3: RU -->
        <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="6" Padding="0,2">
            <Label Grid.Column="0" Text="RU:" TextColor="#CCC" FontSize="13" VerticalOptions="Center" FontAttributes="Bold" WidthRequest="90"/>
            <Entry Grid.Column="1" x:Name="TxtRu" TextColor="#E0E0E0" BackgroundColor="#2A2A3E" FontSize="14" PlaceholderColor="#555" Placeholder="Translation"/>
        </Grid>

        <!-- 4: Context -->
        <Grid Grid.Row="4" ColumnDefinitions="Auto,*" ColumnSpacing="6" Padding="0,2">
            <Label Grid.Column="0" Text="Context:" TextColor="#CCC" FontSize="12" VerticalOptions="Start" WidthRequest="90" Padding="0,6,0,0"/>
            <Editor Grid.Column="1" x:Name="TxtContext" TextColor="#E0E0E0" BackgroundColor="#2A2A3E"
                    FontSize="12" PlaceholderColor="#555" Placeholder="Sentence from audiobook"
                    HeightRequest="56" AutoSize="TextChanges" />
        </Grid>

        <!-- 5: Sentence audio -->
        <Grid Grid.Row="5" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" Padding="0,2">
            <Label Grid.Column="0" Text="Sentence:" TextColor="#CCC" FontSize="12" VerticalOptions="Center" WidthRequest="90"/>
            <Label Grid.Column="1" x:Name="LblSentenceAudio" Text="(not extracted)" TextColor="#888" FontSize="11" VerticalOptions="Center" LineBreakMode="TailTruncation"/>
            <Button Grid.Column="2" x:Name="BtnPreviewSentence" Text="▶" FontSize="12"
                    Clicked="OnPreviewSentenceClicked"
                    BackgroundColor="#444" TextColor="#00B4A6" CornerRadius="6"
                    HeightRequest="32" WidthRequest="44" Padding="0"/>
        </Grid>

        <!-- 6: TTS + Record -->
        <Frame Grid.Row="6" Padding="10,6" CornerRadius="8" BackgroundColor="#1E1E2E" BorderColor="Transparent" HasShadow="False">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                <!-- Google -->
                <Grid Grid.Row="0" ColumnDefinitions="30,Auto,*,Auto" ColumnSpacing="4">
                    <RadioButton Grid.Column="0" x:Name="RbGoogleTts" VerticalOptions="Center" GroupName="tts" IsChecked="True"
                                 CheckedChanged="OnTtsProviderChanged" BackgroundColor="Transparent"/>
                    <Label Grid.Column="1" Text="Google:" TextColor="#CCC" FontSize="11" VerticalOptions="Center"/>
                    <Label Grid.Column="2" x:Name="LblGoogleAudio" Text="(click Preview)" TextColor="#888" FontSize="10" VerticalOptions="Center" LineBreakMode="TailTruncation"/>
                    <Button Grid.Column="3" x:Name="BtnPreviewGoogle" Text="▶" FontSize="10"
                            Clicked="OnPreviewGoogleClicked"
                            BackgroundColor="#444" TextColor="#00B4A6" CornerRadius="4"
                            HeightRequest="26" WidthRequest="38" Padding="0"/>
                </Grid>
                <!-- Deepgram -->
                <Grid Grid.Row="1" ColumnDefinitions="30,Auto,*,Auto" ColumnSpacing="4">
                    <RadioButton Grid.Column="0" x:Name="RbDeepgramTts" VerticalOptions="Center" GroupName="tts"
                                 CheckedChanged="OnTtsProviderChanged" BackgroundColor="Transparent"/>
                    <Label Grid.Column="1" Text="Deepgram:" TextColor="#CCC" FontSize="11" VerticalOptions="Center"/>
                    <Label Grid.Column="2" x:Name="LblDeepgramAudio" Text="(click Preview)" TextColor="#888" FontSize="10" VerticalOptions="Center" LineBreakMode="TailTruncation"/>
                    <Button Grid.Column="3" x:Name="BtnPreviewDeepgram" Text="▶" FontSize="10"
                            Clicked="OnPreviewDeepgramClicked"
                            BackgroundColor="#444" TextColor="#00B4A6" CornerRadius="4"
                            HeightRequest="26" WidthRequest="38" Padding="0"/>
                </Grid>
                <!-- Record -->
                <Grid Grid.Row="2" ColumnDefinitions="30,Auto,*,Auto,Auto" ColumnSpacing="4">
                    <RadioButton Grid.Column="0" x:Name="RbRecord" VerticalOptions="Center" GroupName="tts"
                                 CheckedChanged="OnTtsProviderChanged" BackgroundColor="Transparent"/>
                    <Label Grid.Column="1" Text="Record:" TextColor="#CCC" FontSize="11" VerticalOptions="Center"/>
                    <Label Grid.Column="2" x:Name="LblRecAudio" Text="(tap 🎤 Rec)" TextColor="#888" FontSize="10" VerticalOptions="Center" LineBreakMode="TailTruncation"/>
                    <Button Grid.Column="3" x:Name="BtnRecordAudio" Text="🎤 Rec" FontSize="10"
                            Clicked="OnRecordClicked"
                            BackgroundColor="#444" TextColor="#E04040" CornerRadius="4"
                            HeightRequest="26" WidthRequest="48" Padding="0"/>
                    <Button Grid.Column="4" x:Name="BtnPlayRecord" Text="▶" FontSize="10"
                            Clicked="OnPlayRecordClicked"
                            BackgroundColor="#444" TextColor="#00B4A6" CornerRadius="4"
                            HeightRequest="26" WidthRequest="38" Padding="0"/>
                </Grid>
            </Grid>
        </Frame>

        <!-- 7: Picture -->
        <Frame Grid.Row="7" Padding="10,6" CornerRadius="8" BackgroundColor="#1E1E2E" BorderColor="Transparent" HasShadow="False">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                <Label Grid.Column="0" Text="Picture:" TextColor="#CCC" FontSize="12" VerticalOptions="Center"/>
                <Image Grid.Column="1" x:Name="ImgPreview" Aspect="AspectFit" HeightRequest="32" VerticalOptions="Center"/>
                <Button Grid.Column="2" x:Name="BtnSearchImages" Text="🔍 Search" FontSize="12"
                        Clicked="OnSearchImagesClicked"
                        BackgroundColor="#00B4A6" TextColor="White" CornerRadius="6"
                        HeightRequest="32" Padding="10,0"/>
            </Grid>
        </Frame>

        <!-- 8: Status -->
        <Label Grid.Row="8" x:Name="LblStatus" Text="" TextColor="#888" FontSize="11" Padding="4,2"
               VerticalOptions="End" BackgroundColor="Transparent"/>

        <!-- 9: Buttons -->
        <Grid Grid.Row="9" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,6">
            <Button Grid.Column="0" x:Name="BtnCancel" Text="Cancel" FontSize="14"
                    Clicked="OnCancelClicked"
                    BackgroundColor="#444" TextColor="#CCC" CornerRadius="8"
                    HeightRequest="42" WidthRequest="90"/>
            <Button Grid.Column="2" x:Name="BtnCreate" Text="Create Cards" FontSize="14" FontAttributes="Bold"
                    Clicked="OnCreateClicked"
                    BackgroundColor="#1E3A5F" TextColor="#00B4A6" CornerRadius="8"
                    HeightRequest="42" WidthRequest="140"/>
        </Grid>
    </Grid>
</ContentPage>
