<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="RepeatSegment.Maui.Pages.PlayerPage"
             Title="Player"
             BackgroundColor="#1E1E1E">

    <Grid RowDefinitions="Auto,120,Auto,Auto,Auto,Auto,*,Auto" Padding="0">

        <!-- Row 0: Top toolbar -->
        <HorizontalStackLayout Grid.Row="0" Padding="12,6" Spacing="8">
            <Button x:Name="BtnLoad" Text="📁 Load" FontSize="14"
                    Clicked="OnLoadMenuClicked"
                    BackgroundColor="#2A2A3E" TextColor="#E0E0E0"
                    CornerRadius="8" HeightRequest="36" BorderWidth="0" />
            <Label x:Name="LblFileName" Text="No file loaded"
                   TextColor="#888" FontSize="12" VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Row 1: Waveform / Loading overlay -->
        <Grid Grid.Row="1">
            <skia:SKCanvasView x:Name="WaveformCanvas"
                               PaintSurface="OnWaveformPaint"
                               EnableTouchEvents="True"
                               Touch="OnWaveformTouch"
                               HeightRequest="120" />
            <!-- Loading state overlay -->
            <VerticalStackLayout x:Name="LoadingOverlay" IsVisible="False"
                                   VerticalOptions="Center" HorizontalOptions="Center"
                                   Spacing="8">
                <ActivityIndicator x:Name="LoadingSpinner" IsRunning="False"
                                    Color="#00B4A6" WidthRequest="36" HeightRequest="36" />
                <Label x:Name="LblLoadingStatus" Text="Loading..."
                        TextColor="#E0E0E0" FontSize="18" FontAttributes="Bold"
                        HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Row 2: Slider -->
        <Grid Grid.Row="2" ColumnDefinitions="48,*,48" Padding="10,2">
            <Label Grid.Column="0" x:Name="LblPosition" Text="00:00"
                    TextColor="White" FontSize="11" VerticalOptions="Center" />
            <Slider Grid.Column="1" x:Name="SliderPosition"
                    Minimum="0" Maximum="100" Value="0"
                    ValueChanged="OnSliderValueChanged"
                    DragStarted="OnSliderDragStarted"
                    DragCompleted="OnSliderDragCompleted" />
            <Label Grid.Column="2" x:Name="LblDuration" Text="00:00"
                    TextColor="White" FontSize="11" VerticalOptions="Center"
                    HorizontalTextAlignment="End" />
        </Grid>

        <!-- Row 3: Transport buttons -->
        <HorizontalStackLayout Grid.Row="3" HorizontalOptions="Center" Spacing="3" Padding="2,2">
            <ImageButton x:Name="BtnFirst" Source="first" WidthRequest="42" HeightRequest="42"
                         Clicked="OnFirstClicked" Aspect="AspectFit"
                         BackgroundColor="#555" CornerRadius="6" Padding="5" />
            <ImageButton x:Name="BtnPrev" Source="pre_play" WidthRequest="42" HeightRequest="42"
                         Clicked="OnPrevClicked" Aspect="AspectFit"
                         BackgroundColor="#555" CornerRadius="6" Padding="5" />
            <ImageButton x:Name="BtnRepeat" Source="repeat" WidthRequest="42" HeightRequest="42"
                         Clicked="OnRepeatClicked" Aspect="AspectFit"
                         BackgroundColor="#555" CornerRadius="6" Padding="5" />
            <ImageButton x:Name="BtnPlayGo" Source="play_go" WidthRequest="42" HeightRequest="42"
                         Clicked="OnPlayGoClicked" Aspect="AspectFit"
                         BackgroundColor="#555" CornerRadius="6" Padding="5" />
            <ImageButton x:Name="BtnPlay" Source="play" WidthRequest="42" HeightRequest="42"
                         Clicked="OnPlayClicked" Aspect="AspectFit"
                         BackgroundColor="#555" CornerRadius="6" Padding="5" />
            <ImageButton x:Name="BtnNext" Source="next_play" WidthRequest="42" HeightRequest="42"
                         Clicked="OnNextClicked" Aspect="AspectFit"
                         BackgroundColor="#555" CornerRadius="6" Padding="5" />
            <ImageButton x:Name="BtnLast" Source="last" WidthRequest="42" HeightRequest="42"
                         Clicked="OnLastClicked" Aspect="AspectFit"
                         BackgroundColor="#555" CornerRadius="6" Padding="5" />
        </HorizontalStackLayout>

        <!-- Row 4: Speed, Collapse, Volume -->
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto,Auto,Auto,*" Padding="8,1" ColumnSpacing="6">
            <Picker x:Name="PckSpeed" Grid.Column="1"
                    TextColor="#E0E0E0" TitleColor="#888"
                    WidthRequest="72" FontSize="12"
                    SelectedIndex="6"
                    SelectedIndexChanged="OnSpeedChanged"
                    BackgroundColor="#2D2D2D" />
            <Button x:Name="BtnCollapse" Grid.Column="2" Text="▲" FontSize="12"
                    WidthRequest="30" HeightRequest="30" Padding="0"
                    Clicked="OnCollapseClicked"
                    BackgroundColor="#444" TextColor="#888" CornerRadius="4" />
            <Button x:Name="BtnVolDown" Grid.Column="3" Text="➖" FontSize="16"
                    WidthRequest="30" HeightRequest="30" Padding="0"
                    Clicked="OnVolDownClicked"
                    BackgroundColor="#444" TextColor="White" CornerRadius="4" />
            <Label x:Name="LblVolume" Grid.Column="4" Text="100%"
                    TextColor="#CCC" FontSize="11" VerticalOptions="Center"
                    WidthRequest="36" HorizontalTextAlignment="Center" />
            <Button x:Name="BtnVolUp" Grid.Column="5" Text="➕" FontSize="16"
                    WidthRequest="30" HeightRequest="30" Padding="0"
                    Clicked="OnVolUpClicked"
                    BackgroundColor="#444" TextColor="White" CornerRadius="4" />
        </Grid>

        <!-- Row 5: Segment info -->
        <Label Grid.Row="5" x:Name="LblSegmentInfo"
               Text="" TextColor="#00B4A6" FontSize="11"
               Padding="12,1" HorizontalTextAlignment="Center" />

        <!-- Row 6: Transcription area (8 lines) + future translation space -->
        <ScrollView x:Name="TransScrollView" Grid.Row="6" Padding="12,6" HeightRequest="190">
            <Label x:Name="LblTranscription"
                   Text="No audio loaded. Tap 📁 Load to open an audiobook"
                   TextColor="#888888" FontSize="16" LineBreakMode="WordWrap" />
        </ScrollView>

        <!-- Row 7: Status bar -->
        <Label Grid.Row="7" x:Name="LblStatus"
               Text="Ready" TextColor="#888888" FontSize="10"
               Padding="12,2" BackgroundColor="#2D2D2D" />
    </Grid>

</ContentPage>
